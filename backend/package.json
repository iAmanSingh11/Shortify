{
  "name": "url-shortener-backend",
  "version": "2.0.0",
  "description": "Production-ready URL shortening platform - backend API",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/queues/analytics.worker.js",
    "lint": "eslint src --ext .js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/.bin/jest --runInBand --detectOpenHandles",
